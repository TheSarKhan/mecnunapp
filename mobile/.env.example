# Copy to .env. Only EXPO_PUBLIC_* variables reach the app bundle.
#
# Android emulator reaches the host machine at 10.0.2.2, NOT localhost.
# iOS simulator can use localhost. A physical device needs your LAN IP (e.g. http://192.168.1.20:8080).
EXPO_PUBLIC_API_URL=http://localhost:8080

# Canlı server (web ilə eyni backend): http://173.249.54.197:8090
#
# XƏBƏRDARLIQ — bu ünvan release build-də İŞLƏMİR. Android 9+ və iOS ATS default olaraq
# şifrələnməmiş HTTP-ni bloklayır. Dev build-də görünə bilər, mağaza build-ində yox.
# Düzgün həll: domen + TLS (https). Cleartext istisnası yazmaq JWT-ləri açıq şəbəkəyə çıxarır.

# Google Sign-In. Yalnız development build-də işləyir — Expo Go-nun redirect-ini
# (exp://...) Google qəbul etmir. Client SECRET burada LAZIM DEYİL.
# iOS/Android client-ləri Google Cloud Console-da ayrıca yaradılır.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
