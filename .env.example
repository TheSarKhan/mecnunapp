# Copy to .env for docker compose. Every value below has a dev default —
# compose works without this file. Production must set all of them.

# HS256 signing key. MUST be at least 32 bytes. Change this.
JWT_SECRET=dev-only-secret-change-me-please-32-bytes-min

# Gemini — not wired up yet (chat replies are mocked in this milestone).
GEMINI_API_KEY=

# RevenueCat webhook auth header value.
REVENUECAT_WEBHOOK_SECRET=

# AdMob rewarded-ad server-side verification public key.
ADMOB_SSV_PUBLIC_KEY=
